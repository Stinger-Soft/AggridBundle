    "scripts": {
        "build": "tsc --project tsconfig.build.json && npm run copy-assets",
        "copy-assets": "find ts -name '*.scss' | while read f; do cp --parents \"$f\" dist/ ; done && cd dist && cp -r ts/* . && rm -rf ts",
