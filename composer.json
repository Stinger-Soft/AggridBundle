{
	"name": "stinger-soft/aggrid-bundle",
	"type": "symfony-bundle",
	"description": "Abstraction Layer to create data tables with AgGrid https://www.ag-grid.com/",
	"keywords": [
		"Grid",
		"Table"
	],
	"homepage": "https://www.stinger-soft.net",
	"authors": [
		{
			"name": "Oliver Kotte",
			"email": "oliver.kotte@stinger-soft.net",
			"role": "Developer"
		},
		{
			"name": "Florian Meyer",
			"email": "florian.meyer@stinger-soft.net",
			"role": "Developer"
		}
	],
	"autoload": {
		"psr-4": {
			"StingerSoft\\AggridBundle\\": "src/"
		}
	},
	"license": "Apache-2.0",
	"require": {
		"php": "^8.1",
		"ext-json": "*",
		"knplabs/knp-components": "^5",
		"stinger-soft/php-commons": "^1",
		"symfony/framework-bundle": "^6.4||^7",
		"symfony/property-access": "^6.4||^7",
		"symfony/console": "^6.4||^7",
		"symfony/form": "^6.4||^7",
		"twig/twig": "^3"
	},
	"require-dev": {
		"php-coveralls/php-coveralls": "^2.1.0",
		"doctrine/orm": "^3",
		"doctrine/common": "^3",
		"symfony/validator": "^6.4",
		"symfony/phpunit-bridge": "^6.4",
		"symfony/test-pack": "*",
		"phpstan/phpstan": "^2.1",
		"php-cs-fixer/shim": "^3.94"
	},
	"minimum-stability": "dev",
	"prefer-stable": true,
	"extra": {
		"branch-alias": {
			"dev-master": "3.0.x-dev",
			"dev-develop": "4.0.x-dev"
		}
	}
}
